# Face Attendance System - Environment Variables Example
#
# Copy this file to .env and customize the values for your deployment
# For Hugging Face Spaces, set these in Settings -> Secrets/Variables

# Flask configuration
SECRET_KEY=your-secret-key-here # Required: Generate a strong random key
ADMIN_PASSWORD=your-admin-password # Optional: Admin password for access control
PORT=7860

# Data storage
DATA_DIR=./data # For Hugging Face Spaces with persistent storage: /data

# Face recognition settings
MATCH_THRESHOLD=0.50 # Lower threshold for more lenient matching
MATCH_MARGIN=0.05
BLUR_THRESHOLD=60
MIN_FACE_SIZE=80
MIN_BRIGHTNESS=40
MAX_BRIGHTNESS=225

# Geofencing settings (initial values, overridden by /settings page)
UNIVERSITY_LAT=0.0
UNIVERSITY_LNG=0.0
GEOFENCE_RADIUS_METERS=300
GEOFENCE_MODE=strict
GEOFENCE_MAX_ACCURACY_METERS=150

# Flask configuration
FLASK_DEBUG=false
MAX_CONTENT_LENGTH_MB=25

# Limits
MAX_PHOTO_UPLOADS=10
MAX_CAPTURED_IMAGES=10
MAX_PHOTO_SIZE=5